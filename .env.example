OPENAI_API_KEY=your_key_here

# Runway (prefer RUNWAYML_API_SECRET per Runway docs; RUNWAY_API_KEY still supported)
RUNWAYML_API_SECRET=your_key_here
RUNWAY_API_KEY=your_key_here

GOOGLE_API_KEY=your_key_here
LUMA_API_KEY=your_key_here

# BytePlus / Volcengine ModelArk (Seedance) — model id from Ark console
ARK_API_KEY=your_key_here
BYTEDANCE_API_KEY=your_key_here
BYTEDANCE_ARK_MODEL=your_seedance_model_or_endpoint_id
# Optional: override data-plane base (default BytePlus Singapore)
# BYTEDANCE_ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# BYTEDANCE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
